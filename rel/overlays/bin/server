#!/bin/sh
set -eu

# Prevent rapid crash loops from consuming 100% CPU
STORAGE_DIR="/app/storage"
LAST_START_FILE="$STORAGE_DIR/.last_startup"
RESTART_COUNT_FILE="$STORAGE_DIR/.rapid_restarts"

if [ -d "$STORAGE_DIR" ] && [ -w "$STORAGE_DIR" ]; then
  CURRENT_TIME=$(date +%s)
  if [ -f "$LAST_START_FILE" ] && [ -f "$RESTART_COUNT_FILE" ]; then
    LAST_TIME=$(cat "$LAST_START_FILE")
    DIFF=$((CURRENT_TIME - LAST_TIME))
    if [ "$DIFF" -lt 15 ]; then
      COUNT=$(cat "$RESTART_COUNT_FILE")
      COUNT=$((COUNT + 1))
      echo "$COUNT" > "$RESTART_COUNT_FILE"
      if [ "$COUNT" -ge 5 ]; then
        echo "ERROR: Rapid crash loop detected ($COUNT restarts). Cooling down for 60 seconds to prevent CPU spike..."
        echo "0" > "$RESTART_COUNT_FILE"
        sleep 60
      fi
    else
      echo "0" > "$RESTART_COUNT_FILE"
    fi
  else
    echo "0" > "$RESTART_COUNT_FILE"
  fi
  echo "$CURRENT_TIME" > "$LAST_START_FILE"
fi

cd -P -- "$(dirname -- "$0")"

# Apply host-level performance tunings if running with sufficient privileges
if [ -w /proc/sys/net/core/rmem_max ]; then
  echo "Applying network performance tuning..."
  sysctl -w net.core.rmem_max=750000000 || true
  sysctl -w net.core.wmem_max=750000000 || true
  sysctl -w net.core.rmem_default=750000000 || true
  sysctl -w net.core.wmem_default=750000000 || true
  sysctl -w net.core.netdev_max_backlog=250000 || true
  sysctl -w net.ipv4.udp_mem="379008 504512 759360" || true
  sysctl -w net.netfilter.nf_conntrack_max=1048576 || true
fi

PHX_SERVER=true exec ./hermit start
